# Copy this file to .env for local work.
# Never commit real tokens, passwords, or student-identifying data.

DATABASE_URL=sqlite:///./thinkmate_dev.db
# Primary model: Google Gemini (free tier). Get a key at https://aistudio.google.com/apikey
# When GEMINI_API_KEY is set, Gemini is used first and Poe is the alternate (used
# automatically when Gemini is busy/unavailable). Leave blank to use Poe only.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
HF_API_TOKEN=
HF_MODEL=google/gemma-2-2b-it
# Alternate model provider (used when Gemini is unavailable, or alone if no Gemini key).
POE_API_KEY=
# Must be a valid, active, reliable Poe model. Verify it returns non-empty content
# across a few calls before deploying (some Poe bots time out intermittently).
POE_MODEL=GLM-5
POE_BASE_URL=https://api.poe.com/v1
ADMIN_PASSWORD=change-this-before-deploying
APP_ENV=development
CONSENT_VERSION=v1-2026-06-19
VITE_API_URL=http://localhost:8000
SEED_DEMO_STUDENTS=true
PILOT_ACCESS_CODES=
CORS_ORIGINS=*
# Per-IP sign-in limit per minute. Keep generous: a lab class signs in from one
# campus NAT within the same minute (default 30).
AUTH_RATE_LIMIT_PER_MINUTE=30
# Crossover integrity: Activity 2 cannot start before Activity 1 is complete.
# Leave true for the pilot (the A/B sequence is defined over task order).
ENFORCE_TASK_ORDER=true
# Soft ceiling on tutor exchanges per session; past it the tutor closes with a
# canned wrap-up instead of another paid model call (default 15).
MAX_EXCHANGES=15
