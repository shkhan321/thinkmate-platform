# Copy this file to .env for local work.
# Never commit real tokens, passwords, or student-identifying data.

DATABASE_URL=sqlite:///./thinkmate_dev.db
HF_API_TOKEN=
HF_MODEL=google/gemma-2-2b-it
POE_API_KEY=
# Must be a valid, active, reliable Poe model. Verify it returns non-empty content
# across a few calls before deploying (some Poe bots time out intermittently).
POE_MODEL=GLM-5
POE_BASE_URL=https://api.poe.com/v1
ADMIN_PASSWORD=change-this-before-deploying
APP_ENV=development
CONSENT_VERSION=v1-2026-06-19
VITE_API_URL=http://localhost:8000
SEED_DEMO_STUDENTS=true
PILOT_ACCESS_CODES=
CORS_ORIGINS=*
